{
  "name": "project-task-management-api",
  "version": "1.0.0",
  "description": "Project and Task Management REST API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typeorm": "ts-node-dev ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d src/utils/data-source.ts ./src/migrations/$npm_config_name",
    "migration:run": "npm run typeorm -- migration:run -d src/utils/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/utils/data-source.ts"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/express-validator": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.13.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
